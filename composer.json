{
    "name": "payroad/nowpayments-provider",
    "description": "NOWPayments crypto provider for Payroad",
    "type": "library",
    "require": {
        "php": ">=8.2",
        "payroad/payroad-core": "@dev"
    },
    "require-dev": {
        "phpunit/phpunit": "^10"
    },
    "autoload": {
        "psr-4": {
            "Payroad\\Provider\\NOWPayments\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Tests\\": "tests/"
        }
    },
    "repositories": [
        { "type": "path", "url": "../payroad-core" }
    ],
    "minimum-stability": "dev",
    "prefer-stable": true
}
